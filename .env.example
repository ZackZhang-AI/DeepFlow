# DeepFlow 环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# ============================================
# 模型 API (DeepSeek)
# ============================================
# DeepSeek API Key (从 platform.deepseek.com 获取)
# ============================================
# Demo deployment controls (Vercel + Render)
# ============================================
# Render persistent disk path, e.g. /var/data/deepflow.db
DEEPFLOW_DB_PATH=
# Public demo should keep registration closed and expose a known demo account.
ALLOW_PUBLIC_REGISTRATION=true
DEMO_USERNAME=
DEMO_PASSWORD=
# Set true on public deployments unless Docker sandbox isolation is available.
DISABLE_SANDBOX_TOOL=false
# CORS should be the exact Vercel origin in production, e.g. https://deepflow-demo.vercel.app
CORS_ORIGINS=http://localhost:3000
# Frontend/Vercel only: point the Next.js app at the Render backend.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# Demo abuse/cost limits
# ============================================
RATE_LIMIT_WINDOW_SECONDS=3600
RESEARCH_TASK_RATE_LIMIT_PER_HOUR=20
TOOL_TEST_RATE_LIMIT_PER_HOUR=30
KNOWLEDGE_WRITE_RATE_LIMIT_PER_HOUR=20
ARTIFACT_RATE_LIMIT_PER_HOUR=20
KNOWLEDGE_UPLOAD_MAX_BYTES=5242880

DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ============================================
# 模型 API (阿里百炼 - 备选 Reporter)
# ============================================
# 阿里百炼 API Key (从 dashscope.aliyun.com 获取)
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# ============================================
# 搜索 API (Tavily)
# ============================================
# Tavily API Key (从 tavily.com 获取，免费 1000 credits/月)
TAVILY_API_KEY=tvly-your-tavily-api-key

# ============================================
# 搜索 API (SerpAPI - 备用)
# ============================================
# SerpAPI API Key (从 serpapi.com 获取，免费 250 次/月)
SERPAPI_API_KEY=your-serpapi-api-key

# ============================================
# 模型配置
# ============================================
# Planner 模型
PLANNER_MODEL=deepseek-chat
# Researcher 模型
RESEARCHER_MODEL=deepseek-chat
# Reporter 模型 (可选: deepseek-chat | qwen-max)
REPORTER_MODEL=deepseek-chat
# Reporter 备选模型
REPORTER_FALLBACK_MODEL=qwen-max

# ============================================
# Embedding / 知识库 RAG 配置
# ============================================
EMBEDDING_MODEL=text-embedding-v2
KNOWLEDGE_TOP_K=5
KNOWLEDGE_CANDIDATE_K=20
KNOWLEDGE_SCORE_THRESHOLD=0.20
KNOWLEDGE_VECTOR_WEIGHT=0.70
KNOWLEDGE_KEYWORD_WEIGHT=0.30
KNOWLEDGE_CHUNK_SIZE=1000
KNOWLEDGE_CHUNK_OVERLAP=200
ENABLE_KB_RERANK=false
KB_RERANK_MODEL=gte-rerank-v2
KB_RERANK_TOP_N=5

# ============================================
# 研究配置
# ============================================
# 最大研究步骤数
MAX_STEPS=5
# 每步最大搜索次数
MAX_SEARCH_CALLS=4
# 每步最大抓取页面数
MAX_CRAWL_PAGES=4
# 单次研究最大 token 预算
MAX_TOKEN_BUDGET=100000
# 最大重试次数
MAX_RETRIES=2
